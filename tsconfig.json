{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["agent/**/*.ts", "recorder/**/*.ts", "shared/**/*.ts", "demo/**/*.ts"],
  "exclude": ["node_modules", "dist", "dashboard"]
}
